{
  "server": {
    "port": 18081,
    "host": "localhost"
  },
  "providers": {
    "bigmodel": {
      "apiKey": "${BIGMODEL_API_KEY}",
      "baseURL": "https://open.bigmodel.cn/api/anthropic",
      "transformer": "glm",
      "models": ["glm-4.7", "glm-4.6v", "glm-4.5-air"]
    }
  },
  "router": {
    "routes": {
      "default": "bigmodel:glm-4.7"
    },
    "maxRetries": 1,
    "retryDelay": "500ms"
  }
}
